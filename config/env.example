
# 数据源凭证配置 (模板)
# 复制此文件为 config/.env 并填入实际值
# config/.env 在 .gitignore 中，不会被提交到 git

# Tushare (tushare.pro) — 量化数据接口
# 注册地址: https://tushare.pro/register
# token 获取: 登录后 → 个人主页 → 接口TOKEN
# 免费 tier: 200 calls/min
TUSHARE_TOKEN=your_tushare_token_here

# JQData (聚宽) — 基本面/估值数据
# 注册地址: https://www.joinquant.com
# 凭证格式: 用户名=手机号，密码=JQData 密码
JQDATA_USER=your_mobile_number
JQDATA_PASS=your_jqdata_password
